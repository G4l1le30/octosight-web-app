# Backend Configuration
MYSQL_USER=octouser
MYSQL_PASSWORD=octopassword
MYSQL_DATABASE=octosight_db
MYSQL_HOST=db
MYSQL_PORT=3306

# Security
SECRET_KEY=generate_a_random_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ML & AI
GEMINI_API_KEY=your_gemini_api_key_here
ML_MODEL_PATH=models/spam_pipeline.pkl

# Application
ENVIRONMENT=production
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
UPLOAD_DIR=uploads
WHITELIST_PATH=data/whitelist.txt

# Default Admin (Created on first run if DB is empty)
DEFAULT_ADMIN_EMAIL=admin@octosight.id
DEFAULT_ADMIN_PASSWORD=admin123

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
